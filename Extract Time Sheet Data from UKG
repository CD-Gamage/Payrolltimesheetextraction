                "userProperties": [],
                "typeProperties": {
                    "method": "POST",
                    "headers": {
                        "api-key": {
                            "value": "@variables('APIKey')",
                            "type": "Expression"
                        },
                        "Accept": "application/json",
                        "Content-Type": "application/json"
                    },
                    "url": {
                        "value": "@concat(variables('BaseURI'),'/v1/login')",
                        "type": "Expression"
                    },
                    "body": {
                        "value": "@concat('{\n  \"credentials\": {\n    \"username\": \"',variables('APIUserName'),'\",\n    \"password\": \"',variables('APIPassword'),'\",\n    \"company\": \"',variables('CompanyId'),'\"\n  }\n}')",
