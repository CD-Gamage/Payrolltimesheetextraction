                    "enableSkipIncompatibleRow": false,
                    "translator": {
                        "type": "TabularTranslator",
                        "mappings": [
                            {
                                "source": {
                                    "path": "$['result']['body']"
                                },
                                "sink": {
                                    "name": "XMLData"
                                }
                            }
                        ],
                        "collectionReference": "",
                        "mapComplexValuesToString": true
