            {
                "name": "Copy Timesheet Data to SQL",
                "type": "Copy",
                "dependsOn": [
                    {
                        "activity": "Set Auth Key Variable",
                        "dependencyConditions": [
                            "Succeeded"
                        ]
                    }
                ],
                "policy": {
                    "timeout": "7.00:00:00",
                    "retry": 0,
                    "retryIntervalInSeconds": 30,
                    "secureOutput": false,
                    "secureInput": false
                },
                "userProperties": [],
                "typeProperties": {
                    "source": {
                        "type": "XmlSource",
                        "storeSettings": {
                            "type": "HttpReadSettings",
                            "requestMethod": "POST",
                            "additionalHeaders": {
                                "value": "@{concat('Content-Type: application/json\nAccept: application/xml\nHost: secure.workforceready.com.au:443\nAuthentication: Bearer ',variables('AuthKey'))}",
                                "type": "Expression"
                            },
                            "requestBody": {
                                "value": "@{concat('{\n   \"company\":{\n      \"short_name\":\"',variables('CompanyId'),'\"\n   },\n   \"selectors\":[\n      {\n         \"name\":\"EntryDate\",\n         \"parameters\":{\n            \"RangeType\":2,\n            \"FromDate\":\"',pipeline().parameters.timesheetStartDate,'\",\n            \"ToDate\":\"',pipeline().parameters.timesheetEndDate,'\"\n         }\n      }\n   ]\n}')}",
                                "type": "Expression"
                            },
                            "requestTimeout": ""
                        },
                        "formatSettings": {
                            "type": "XmlReadSettings",
                            "validationMode": "none",
                            "detectDataType": true,
                            "namespaces": true
                        }
